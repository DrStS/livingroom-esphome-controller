{
  "version": 6,
  "configurePresets": [{
    "name": "default",
    "displayName": "Default Ninja Debug",
    "generator": "Ninja",
    "binaryDir": "${sourceDir}/build/default",
    "cacheVariables": {"CMAKE_BUILD_TYPE": "Debug", "CMAKE_CXX_STANDARD": "20", "CMAKE_CXX_STANDARD_REQUIRED": "ON"}
  }],
  "buildPresets": [{"name": "default", "configurePreset": "default"}],
  "testPresets": [{"name": "default", "configurePreset": "default", "output": {"outputOnFailure": true}}]
}
